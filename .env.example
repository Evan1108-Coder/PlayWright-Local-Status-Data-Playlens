# PlayLens Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# See ENV.md for detailed documentation on each variable.

# --- AI Configuration (optional, server-side only) ---
# Get your API key from https://www.minimax.io/
# Without this key, PlayLens works normally but AI features are disabled.
# NOTE: This key is NOT prefixed with VITE_ — it stays on the server and is
# proxied through /api/ai/complete so it is never exposed to the browser.
MINIMAX_API_KEY=
MINIMAX_MODEL=minimax-text-01

# --- Backend API ---
# Base URL for the PlayLens backend server
VITE_PLAYLENS_API_BASE=http://127.0.0.1:4174

# --- Storage ---
# How session data is stored: "app-data" (central) or "project-local" (per-project)
VITE_PLAYLENS_STORAGE_MODE=app-data

# --- AI Agent ---
# Default agent permission mode: "read-only", "ask-before-acting", "trusted-actions", "full-operator"
VITE_PLAYLENS_AGENT_MODE=ask-before-acting

# --- AI Feature Flag (frontend) ---
# Set to "true" to show AI features in the dashboard (key itself stays server-side)
VITE_PLAYLENS_AI_ENABLED=true
